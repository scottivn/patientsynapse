# PatientSynapse Environment Configuration
# Copy to .env and fill in your values

# ---- EMR Provider ----
# Options: ecw, athena
EMR_PROVIDER=ecw
EMR_REDIRECT_URI=https://localhost:8443/api/auth/callback

# ---- eCW (eClinicalWorks) — used when EMR_PROVIDER=ecw ----
ECW_FHIR_BASE_URL=https://<your-ecw-instance>.ecwcloud.com/fhir/r4/<practice_code>
ECW_CLIENT_ID=<your-ecw-client-id>
ECW_JWKS_URL=https://localhost:8443/.well-known/jwks.json
ECW_TOKEN_URL=https://<your-ecw-instance>.ecwcloud.com/token
ECW_AUTHORIZE_URL=https://<your-ecw-instance>.ecwcloud.com/authorize

# ---- Athena (athenahealth) — used when EMR_PROVIDER=athena ----
ATHENA_FHIR_BASE_URL=https://api.platform.athenahealth.com/fhir/r4
ATHENA_CLIENT_ID=<your-athena-client-id>
ATHENA_CLIENT_SECRET=<your-athena-client-secret>
ATHENA_AUTHORIZE_URL=https://api.platform.athenahealth.com/oauth2/v1/authorize
ATHENA_TOKEN_URL=https://api.platform.athenahealth.com/oauth2/v1/token
ATHENA_PRACTICE_ID=<your-athena-practice-id>

# ---- LLM Provider ----
# Options: grok, openai, anthropic, ollama
LLM_PROVIDER=grok

# Grok (X.AI)
XAI_API_KEY=<your-xai-api-key>
XAI_MODEL=grok-3

# OpenAI (future)
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o

# Anthropic (future)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---- App Settings ----
APP_SECRET_KEY=<generate-a-random-secret-key>
APP_HOST=0.0.0.0
APP_PORT=8443
APP_ENV=development
LOG_LEVEL=INFO

# ---- Fax Processing ----
FAX_POLL_INTERVAL_SECONDS=300
FAX_UPLOAD_DIR=./uploads

# ---- Database (SQLite for local, PostgreSQL for prod) ----
DATABASE_URL=sqlite:///./patientsynapse.db
