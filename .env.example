# PatientBridge Environment Configuration
# Copy to .env and fill in your values

# ---- eCW FHIR API ----
ECW_FHIR_BASE_URL=https://<your-ecw-instance>.ecwcloud.com/fhir/r4/<practice_code>
ECW_CLIENT_ID=<your-ecw-client-id>
ECW_JWKS_URL=https://localhost:8443/.well-known/jwks.json
ECW_REDIRECT_URI=https://localhost:8443/auth/callback
ECW_TOKEN_URL=https://<your-ecw-instance>.ecwcloud.com/token
ECW_AUTHORIZE_URL=https://<your-ecw-instance>.ecwcloud.com/authorize

# ---- LLM Provider ----
# Options: grok, openai, anthropic, ollama
LLM_PROVIDER=grok

# Grok (X.AI)
XAI_API_KEY=<your-xai-api-key>
XAI_MODEL=grok-3

# OpenAI (future)
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o

# Anthropic (future)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---- App Settings ----
APP_SECRET_KEY=<generate-a-random-secret-key>
APP_HOST=0.0.0.0
APP_PORT=8443
APP_ENV=development
LOG_LEVEL=INFO

# ---- Fax Processing ----
FAX_POLL_INTERVAL_SECONDS=300
FAX_UPLOAD_DIR=./uploads

# ---- Database (SQLite for local, PostgreSQL for prod) ----
DATABASE_URL=sqlite:///./patientbridge.db
