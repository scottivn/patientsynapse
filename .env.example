# PatientSynapse Environment Configuration
# Copy to .env and fill in your values

# ---- EMR Provider ----
# Options: ecw, athena
EMR_PROVIDER=ecw
EMR_REDIRECT_URI=https://localhost:8443/api/auth/callback

# ---- eCW (eClinicalWorks) — used when EMR_PROVIDER=ecw ----
ECW_FHIR_BASE_URL=https://staging-fhir.ecwcloud.com/fhir/r4/<practice_code>
ECW_CLIENT_ID=<your-ecw-client-id>
ECW_JWKS_URL=https://<your-domain>/.well-known/jwks.json
ECW_TOKEN_URL=https://staging-oauthserver.ecwcloud.com/oauth/oauth2/token
ECW_AUTHORIZE_URL=https://staging-oauthserver.ecwcloud.com/oauth/oauth2/authorize

# ---- Athena (athenahealth) — used when EMR_PROVIDER=athena ----
# Set ATHENA_SANDBOX=true to use preview.platform.athenahealth.com (no prod data)
ATHENA_SANDBOX=false
ATHENA_FHIR_BASE_URL=https://api.platform.athenahealth.com
ATHENA_CLIENT_ID=<your-athena-client-id>
ATHENA_CLIENT_SECRET=<your-athena-client-secret>
ATHENA_AUTHORIZE_URL=https://api.platform.athenahealth.com/oauth2/v1/authorize
ATHENA_TOKEN_URL=https://api.platform.athenahealth.com/oauth2/v1/token
ATHENA_PRACTICE_ID=<your-athena-practice-id>
# Brand and CSG IDs for FHIR R4 URL routing (default 1/1 works for most practices)
ATHENA_BRAND_ID=1
ATHENA_CSG_ID=1

# ---- Stub FHIR (for testing without any EMR connection) ----
# Set to true to skip OAuth entirely and use an in-memory patient store.
# Full pipeline still runs: OCR → LLM extraction → patient match/create → ServiceRequest.
USE_STUB_FHIR=false

# ---- LLM Provider ----
# Options: grok, openai, anthropic, ollama, bedrock
LLM_PROVIDER=grok

# Grok (X.AI)
XAI_API_KEY=<your-xai-api-key>
XAI_MODEL=grok-3

# OpenAI
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o

# Anthropic (direct API)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# AWS Bedrock (HIPAA-eligible under AWS BAA)
# No API key needed — uses IAM role (EC2 instance profile) or AWS env vars
# Use inference profile IDs (us. prefix). Run: aws bedrock list-inference-profiles --region us-east-1
# Check exact model IDs in console: https://console.aws.amazon.com/bedrock/home#/inference-profiles
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250929-v1:0
BEDROCK_REGION=us-east-1

# ---- App Settings ----
APP_SECRET_KEY=<generate-a-random-secret-key>
APP_HOST=0.0.0.0
APP_PORT=8443
APP_ENV=development
LOG_LEVEL=INFO

# ---- Admin Auth ----
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin

# ---- Session / JWT ----
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# SESSION_INACTIVITY_TIMEOUT_MINUTES=15

# ---- Fax Processing ----
FAX_POLL_INTERVAL_SECONDS=300
FAX_UPLOAD_DIR=./uploads

# ---- Database (SQLite for local, PostgreSQL for prod) ----
DATABASE_URL=sqlite:///./patientsynapse.db
